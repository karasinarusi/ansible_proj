upstream hello-world-backend {
    {% for host in groups['k8s_workers'] %}
    # Автоматически берем IP-адрес каждого воркера из инвентаря
    server {{ hostvars[host]['ansible_host'] }}:30001;
    {% endfor %}
}

server {
    listen {{ vip_address }}:80;
    server_name _;

    location / {
        proxy_pass http://hello-world-backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
